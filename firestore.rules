rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Logs (auditLogs, activityLogs, emailLogs, eventApprovalLogs)
    // Written strictly by the Backend (Admin SDK). 
    // Client reads are DENIED to protect operational/sensitive data.
    match /auditLogs/{logId} {
      allow read, write: if false; 
    }
    match /activityLogs/{logId} {
      allow read, write: if false; 
    }
    match /emailLogs/{logId} {
      allow read, write: if false; 
    }
    match /eventApprovalLogs/{logId} {
      allow read, write: if false; 
    }
    
    // 2. Events Collection
    // Read: Authenticated users can read (needed for realtime onSnapshot).
    // Write: Strictly enforced in the backend (Express API).
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // 3. User Profiles & Settings
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Block privilege escalation: Users cannot modify their role, department, or organizer status.
      allow write: if request.auth.uid == userId 
                   && (
                     (resource == null && !request.resource.data.keys().hasAny(['role', 'department', 'isApprovedOrganizer'])) ||
                     (resource != null && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'department', 'isApprovedOrganizer', 'email']))
                   );
    }
    
    // 4. Legacy / Root Collections
    // Written via backend transactions, but may be read by frontend.
    match /eventRegistrations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /eventAttendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /eventFeedback/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Allow collectionGroup queries for 'members' across all classes
    // Secured: Only authenticated users (admins, faculty, logged-in students) can read it.
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }
    
    // 5. Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Logs (auditLogs, activityLogs, emailLogs, eventApprovalLogs)
    // Written strictly by the Backend (Admin SDK). 
    // EmailAudit.jsx reads emailLogs directly from the frontend, so we must allow read for authenticated users (or restrict by role if custom claims are set, but for safety layer, isAuthenticated is the baseline).
    match /auditLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
    match /activityLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
    match /emailLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
    match /eventApprovalLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }
    
    // 2. Events Collection
    // Read: Authenticated users can read (needed for realtime onSnapshot).
    // Write: Strictly enforced in the backend (Express API).
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // 3. User Profiles & Settings
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId; // Basic ownership
    }
    
    // 4. Legacy / Root Collections
    // Written via backend transactions, but may be read by frontend.
    match /eventRegistrations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /eventAttendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /eventFeedback/{docId} {
      allow read: if isAuthenticated();
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Allow collectionGroup queries for 'members' across all classes
    // Secured: Only authenticated users (admins, faculty, logged-in students) can read it.
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }
    
    // 5. Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
